# ========================================
# QQ-to-OpenAI Bridge 配置
# 复制此文件为 .env 并填入你的值
# ========================================

# Bridge API 监听端口
BRIDGE_PORT=9520

# Web 控制面板端口
WEBUI_PORT=9521

# NapCat OneBot WebSocket 地址
NAPCAT_WS_URL=ws://127.0.0.1:3001

# NapCat OneBot 鉴权 Token (如果设置了的话)
NAPCAT_TOKEN=

# 默认目标群号
DEFAULT_GROUP_ID=

# 默认目标好友 QQ (与 group 二选一，群号优先)
DEFAULT_USER_ID=

# 白名单用户 QQ (逗号分隔，只捕获这些用户的回复；留空=不过滤)
WHITELIST_USERS=

# 回复等待超时 (毫秒)
REPLY_TIMEOUT_MS=60000

# 发送限流间隔 (毫秒)
RATE_LIMIT_MS=1500

# 超过此字数自动用合并转发(聊天记录)包裹发送，防止截断 (0=禁用)
FORWARD_MSG_THRESHOLD=2000

# 客户端调用 Bridge API 的 Bearer Token
API_KEY=sk-qq-bridge
